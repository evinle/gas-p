{
  "name": "@evinle/gas-p",
  "version": "0.1.0",
  "description": "Local development runtime for Google Apps Script TypeScript codebases",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evinle/gas-p.git"
  },
  "homepage": "https://github.com/evinle/gas-p#readme",
  "bugs": {
    "url": "https://github.com/evinle/gas-p/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "./vite": "./dist/adapters/vitePlugin.js",
    "./client": "./dist/client/transportShim.js",
    "./fixtures": "./dist/core/fixtures.js"
  },
  "bin": {
    "gas-p": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:stubs": "tsx src/generator/generate.ts",
    "generate:stubs:check": "tsx src/generator/generate.ts --check"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "googleapis": "^173.0.0",
    "open": "^11.0.0",
    "tsx": "^4.19.4"
  },
  "peerDependencies": {
    "vite": "^7.3.6"
  },
  "devDependencies": {
    "@types/google-apps-script": "^2.0.11",
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  }
}

{
  "name": "gas-p",
  "version": "0.1.0",
  "description": "Local development runtime for Google Apps Script TypeScript codebases",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
